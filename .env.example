# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxx
CLERK_SECRET_KEY=sk_test_xxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxxx
SUPABASE_SERVICE_ROLE_KEY=xxxx

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000
ADMIN_PASSWORD=admin123

# Storage backend: mock | google_sheets | supabase | tencent_docs
# Use mock for offline dev; use supabase when NEXT_PUBLIC_SUPABASE_URL is configured
STORAGE_BACKEND=mock

# Optional: Postgres URI for `npm run db:setup` (Supabase → Settings → Database)
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@aws-0-xxx.pooler.supabase.com:6543/postgres

# Google Sheets (optional)
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=

# Legacy Supabase env aliases (optional)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Tencent Docs (optional)
TENCENT_DOCS_APP_ID=
TENCENT_DOCS_APP_SECRET=

# AI — 链接/图片解析（Claude / OpenAI / Gemini 三选一或自动）
# PARSE_MODE: mock | claude | openai | gemini（留空且配置了 Key 时自动选择）
# 图片识别需配置至少一个 API Key 并将 PARSE_MODE 设为对应 provider 或留空
CLAUDE_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
PARSE_MODE=mock

# Legacy site URL alias
SITE_URL=http://localhost:3000
